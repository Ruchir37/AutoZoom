import android.content.Context;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.CheckBox;
import android.widget.LinearLayout;
import android.widget.TextView;

import androidx.recyclerview.widget.RecyclerView;

import java.util.List;

public class ConsentAdapter extends RecyclerView.Adapter<ConsentAdapter.ViewHolder> {

    private Context context;
    private List<ConsentSection> list;

    public ConsentAdapter(Context context, List<ConsentSection> list) {
        this.context = context;
        this.list = list;
    }

    @Override
    public ViewHolder onCreateViewHolder(ViewGroup parent, int viewType) {

        View view = LayoutInflater.from(context)
                .inflate(R.layout.item_consent_section, parent, false);

        return new ViewHolder(view);
    }

    @Override
    public void onBindViewHolder(ViewHolder holder, int position) {

        ConsentSection section = list.get(position);

        holder.tvTitle.setText(section.getTitle());
        holder.tvDescription.setText(section.getDescription());

        holder.checkboxContainer.removeAllViews();

        for (String option : section.getOptions()) {

            CheckBox checkBox = new CheckBox(context);
            checkBox.setText(option);

            holder.checkboxContainer.addView(checkBox);
        }
    }

    @Override
    public int getItemCount() {
        return list.size();
    }

    public static class ViewHolder extends RecyclerView.ViewHolder {

        TextView tvTitle, tvDescription;
        LinearLayout checkboxContainer;

        public ViewHolder(View itemView) {
            super(itemView);

            tvTitle = itemView.findViewById(R.id.tvTitle);
            tvDescription = itemView.findViewById(R.id.tvDescription);
            checkboxContainer = itemView.findViewById(R.id.checkboxContainer);
        }
    }
}
