package com.sbi.upi.customerMode.modules.ccms;

import android.content.Context;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.CheckBox;
import android.widget.LinearLayout;
import android.widget.TextView;

import androidx.recyclerview.widget.RecyclerView;

import com.sbi.upi.R;
import com.sbi.upi.customerMode.modules.ccms.model.BankProduct;
import com.sbi.upi.customerMode.modules.ccms.model.DpConsent;

import java.util.ArrayList;

import butterknife.BindView;
import butterknife.ButterKnife;

public class OptionalConsentRecyclerAdapter extends RecyclerView.Adapter<OptionalConsentRecyclerAdapter.ViewHolder> {

    Context context;
    public ArrayList<DpConsent> body;

    public OptionalConsentRecyclerAdapter(ArrayList<DpConsent> body) {
        this.body = body;
    }

    @Override
    public ViewHolder onCreateViewHolder(ViewGroup parent, int viewType) {
        context = parent.getContext();
        View itemView = LayoutInflater.from(parent.getContext()).inflate(R.layout.item_ccms, parent, false);
        return new ViewHolder(itemView);
    }

    @Override
    public void onBindViewHolder(ViewHolder viewHolder, int position) {

        DpConsent consent = body.get(position);

        viewHolder.tv_title.setText(consent.purposes.get(0).title);
        viewHolder.tv_content.setText(consent.purposes.get(0).description);

        ArrayList<BankProduct> bankProducts = consent.purposes.get(0).bankProducts;

        viewHolder.checkboxContainer.removeAllViews();

        // If there are bank products → create dynamic checkboxes
        if (bankProducts != null && bankProducts.size() > 0) {

            viewHolder.cb_status.setVisibility(View.GONE);

            for (int i = 0; i < bankProducts.size(); i++) {

                BankProduct product = bankProducts.get(i);

                CheckBox checkBox = new CheckBox(context);
                checkBox.setText(product.label);
                checkBox.setChecked(product.isSelected);

                int index = i;

                checkBox.setOnCheckedChangeListener((buttonView, isChecked) -> {
                    bankProducts.get(index).isSelected = isChecked;
                });

                viewHolder.checkboxContainer.addView(checkBox);
            }

        } else {

            // Single checkbox like Analytics / Email
            viewHolder.cb_status.setVisibility(View.VISIBLE);
            viewHolder.cb_status.setChecked(consent.isSelected);

            viewHolder.cb_status.setOnCheckedChangeListener((buttonView, isChecked) -> {
                consent.isSelected = isChecked;
            });
        }
    }

    @Override
    public int getItemCount() {
        return body.size();
    }

    public class ViewHolder extends RecyclerView.ViewHolder {

        @BindView(R.id.tv_title)
        TextView tv_title;

        @BindView(R.id.tv_content)
        TextView tv_content;

        @BindView(R.id.checkboxContainer)
        LinearLayout checkboxContainer;

        @BindView(R.id.cb_status)
        CheckBox cb_status;

        public ViewHolder(View itemView) {
            super(itemView);
            ButterKnife.bind(this, itemView);
        }
    }

    // Method to collect selected values
    public ArrayList<String> getSelectedValues() {

        ArrayList<String> selectedList = new ArrayList<>();

        for (DpConsent consent : body) {

            ArrayList<BankProduct> products = consent.purposes.get(0).bankProducts;

            if (products != null && products.size() > 0) {

                for (BankProduct product : products) {

                    if (product.isSelected) {
                        selectedList.add(product.label);
                    }
                }

            } else {

                if (consent.isSelected) {
                    selectedList.add(consent.purposes.get(0).title);
                }
            }
        }

        return selectedList;
    }
}
