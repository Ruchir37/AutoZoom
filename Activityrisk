package com.example.security;

import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.provider.Settings;
import android.view.LayoutInflater;
import android.view.View;
import android.widget.ImageView;
import android.widget.LinearLayout;
import android.widget.TextView;

import androidx.annotation.Nullable;
import androidx.appcompat.app.AppCompatActivity;

import com.google.android.material.button.MaterialButton;

import java.util.ArrayList;
import java.util.List;

public class EnvironmentRiskActivity extends AppCompatActivity {

    private LinearLayout riskContainer;
    private MaterialButton btnOpenSettings;
    private MaterialButton btnRetry;

    private final List<RiskItem> riskItems = new ArrayList<>();

    // Simulated backend/environment verdicts
    // Replace these with your actual backend response flags
    private boolean knownAccessRisk = true;
    private boolean overlayDetected = true;
    private boolean accessibilityEnabled = true;

    @Override
    protected void onCreate(@Nullable Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        setContentView(R.layout.activity_environment_risk);

        initViews();

        prepareRiskItems(
                knownAccessRisk,
                overlayDetected,
                accessibilityEnabled
        );

        populateRiskItems();
    }

    private void initViews() {

        riskContainer = findViewById(R.id.riskContainer);

        btnOpenSettings = findViewById(R.id.btnOpenSettings);
        btnRetry = findViewById(R.id.btnRetry);

        findViewById(R.id.ivClose).setOnClickListener(v -> finish());

        btnOpenSettings.setOnClickListener(v -> {
            openRelevantSettings();
        });

        btnRetry.setOnClickListener(v -> {

            // Retry your integrity flow
            retryIntegrityValidation();
        });
    }

    private void prepareRiskItems(
            boolean knownAccessRisk,
            boolean overlayDetected,
            boolean accessibilityEnabled
    ) {

        riskItems.clear();

        if (knownAccessRisk) {

            riskItems.add(new RiskItem(
                    R.drawable.ic_visibility,
                    "Apps with screen access detected",
                    "Some apps may be able to view or capture your screen."
            ));
        }

        if (overlayDetected) {

            riskItems.add(new RiskItem(
                    R.drawable.ic_overlay,
                    "Screen overlay enabled",
                    "Apps displaying over other apps may compromise security."
            ));
        }

        if (accessibilityEnabled) {

            riskItems.add(new RiskItem(
                    R.drawable.ic_accessibility,
                    "Accessibility services active",
                    "Some services may access sensitive information."
            ));
        }
    }

    private void populateRiskItems() {

        riskContainer.removeAllViews();

        LayoutInflater inflater = LayoutInflater.from(this);

        for (RiskItem item : riskItems) {

            View view = inflater.inflate(
                    R.layout.item_risk,
                    riskContainer,
                    false
            );

            ImageView ivIcon = view.findViewById(R.id.ivIcon);
            TextView tvTitle = view.findViewById(R.id.tvTitle);
            TextView tvDescription = view.findViewById(R.id.tvDescription);

            ivIcon.setImageResource(item.icon);
            tvTitle.setText(item.title);
            tvDescription.setText(item.description);

            riskContainer.addView(view);
        }
    }

    private void openRelevantSettings() {

        try {

            // Accessibility settings
            Intent accessibilityIntent =
                    new Intent(Settings.ACTION_ACCESSIBILITY_SETTINGS);

            startActivity(accessibilityIntent);

        } catch (Exception e) {

            e.printStackTrace();

            try {

                Intent intent =
                        new Intent(Settings.ACTION_SETTINGS);

                startActivity(intent);

            } catch (Exception ex) {

                ex.printStackTrace();
            }
        }
    }

    private void retryIntegrityValidation() {

        // TODO:
        // Call backend again
        // Re-trigger Play Integrity
        // Validate verdict again

        finish();
    }

    public static class RiskItem {

        int icon;
        String title;
        String description;

        public RiskItem(
                int icon,
                String title,
                String description
        ) {

            this.icon = icon;
            this.title = title;
            this.description = description;
        }
    }
}
